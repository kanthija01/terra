# Server-only secret. Do NOT prefix this with NEXT_PUBLIC_.
# It is read only inside src/lib/gemini-server.ts, which is only ever
# imported by the Next.js API routes in src/app/api/*/route.ts.
# Route handlers run exclusively on the server, so this value is never
# sent to the browser or bundled into client JavaScript.
GEMINI_API_KEY=your_gemini_api_key

# Firebase web config. These ARE safe to expose to the browser by design —
# Firebase access control is enforced server-side via Firestore/Storage
# security rules, not by hiding these values. They still belong in
# .env.local (ignored by git), not committed to version control.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
